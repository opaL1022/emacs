;; -*- mode: emacs-lisp; coding: utf-8-unix -*-
;; Minibuffer history file, automatically generated by ‘savehist’.

(setq savehist-minibuffer-history-variables '(command-history extended-command-history yes-or-no-p-history file-name-history))
(setq command-history '((find-file "~/Documents/" t)))
(setq yes-or-no-p-history '("yes" "no" "yes"))
(setq file-name-history '("~/Documents/" "~/Documents/codes/" "~/Documents/" "~/.config/" "~/Documents/"))
